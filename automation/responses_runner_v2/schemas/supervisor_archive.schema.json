{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Responses Runner V2 Supervisor Archive",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "archive_id",
    "archived_at",
    "reason",
    "source",
    "included_artifacts",
    "request_hash",
    "scaffold_hash",
    "request_evidence",
    "scaffold_evidence",
    "unchanged_input_evidence",
    "retry_budget_before",
    "retry_budget_after",
    "rerun_as_is_eligible"
  ],
  "properties": {
    "schema_version": {
      "const": "responses_runner_v2.supervisor_archive.v1"
    },
    "archive_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
    },
    "archived_at": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "run_dir",
        "stage_id"
      ],
      "properties": {
        "run_dir": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "workflow_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "response_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "included_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_path",
          "archive_path",
          "sha256",
          "bytes"
        ],
        "properties": {
          "source_path": {
            "type": "string",
            "minLength": 1
          },
          "archive_path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "request_hash": {
      "type": "string",
      "minLength": 1
    },
    "scaffold_hash": {
      "type": "string"
    },
    "request_evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status",
        "request_hash",
        "evidence_files",
        "model_tool_settings"
      ]
    },
    "scaffold_evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status",
        "scaffold_hash"
      ]
    },
    "unchanged_input_evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "request_hash_before",
        "scaffold_hash_before",
        "rerun_requires_same_hashes"
      ],
      "properties": {
        "request_hash_before": {
          "type": "string",
          "minLength": 1
        },
        "scaffold_hash_before": {
          "type": "string"
        },
        "rerun_requires_same_hashes": {
          "const": true
        }
      }
    },
    "retry_budget_before": {
      "type": "object"
    },
    "retry_budget_after": {
      "type": "object"
    },
    "rerun_as_is_eligible": {
      "type": "boolean"
    }
  }
}
