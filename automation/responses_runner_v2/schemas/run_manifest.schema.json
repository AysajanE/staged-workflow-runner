{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Responses Runner V2 Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "run_name",
    "workflow_id",
    "workflow_manifest_path",
    "workflow_manifest_sha256",
    "run_dir",
    "started_at",
    "updated_at",
    "status",
    "stage_order",
    "stages"
  ],
  "properties": {
    "schema_version": {
      "const": "responses_runner_v2.run_manifest.v1"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
    },
    "run_name": {
      "type": "string",
      "minLength": 1
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
    },
    "workflow_manifest_path": {
      "type": "string",
      "minLength": 1
    },
    "workflow_manifest_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "run_dir": {
      "type": "string",
      "minLength": 1
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "created",
        "running",
        "waiting_for_review",
        "completed",
        "failed",
        "cancelled",
        "blocked"
      ]
    },
    "current_stage_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
    },
    "stage_order": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "operator_overrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primary_job_inputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reference_context": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "review_bundles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "skip_token_count": {
          "type": "boolean"
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stageSummary"
      }
    }
  },
  "$defs": {
    "responseStatus": {
      "enum": [
        "queued",
        "in_progress",
        "completed",
        "failed",
        "cancelled",
        "incomplete"
      ]
    },
    "stageStatus": {
      "enum": [
        "prepared",
        "submitted",
        "in_progress",
        "waiting_for_review",
        "completed",
        "failed",
        "cancelled",
        "incomplete",
        "blocked"
      ]
    },
    "stageSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_id",
        "stage_number",
        "gate",
        "stage_dir",
        "status"
      ],
      "properties": {
        "stage_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
        },
        "stage_number": {
          "type": "integer",
          "minimum": 1
        },
        "gate": {
          "enum": [
            "auto",
            "review_required",
            "terminal"
          ]
        },
        "stage_dir": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/stageStatus"
        },
        "response_id": {
          "type": "string",
          "minLength": 1
        },
        "response_status": {
          "$ref": "#/$defs/responseStatus"
        },
        "checkpoint_path": {
          "type": "string",
          "minLength": 1
        },
        "input_manifest_json_path": {
          "type": "string",
          "minLength": 1
        },
        "response_markdown_path": {
          "type": "string",
          "minLength": 1
        },
        "response_markdown_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "response_json_path": {
          "type": "string",
          "minLength": 1
        },
        "response_json_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "structured_output_path": {
          "type": "string",
          "minLength": 1
        },
        "structured_output_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "review_bundle_path": {
          "type": "string",
          "minLength": 1
        },
        "review_approved": {
          "type": "boolean"
        },
        "approved_from_status": {
          "$ref": "#/$defs/stageStatus"
        },
        "token_preflight_path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
